---
import "../styles/custom.css"
const title = 'Contact — Vectis Mail'
---
<html lang="en">
<head>
	<meta charset="utf-8" />
	<meta name="viewport" content="width=device-width, initial-scale=1" />
	<title>{title}</title>
</head>
<body class="marketing-page">
	<nav class="marketing-nav">
		<a href="/" class="logo">Vectis Mail</a>
		<div>
			<a href="/features">Features</a>
			<a href="/pricing">Pricing</a>
			<a href="/docs/getting-started">Docs</a>
			<a href="/about">About</a>
			<a href="/contact">Contact</a>
		</div>
	</nav>

	<section class="section" style="max-width: 600px;">
		<h2>Get in Touch</h2>
		<p class="subtitle">Questions about Vectis Mail? Enterprise pricing? Integration support? We'd love to hear from you.</p>

		<div class="feature-card" style="margin-bottom: 2rem;">
			<h3>General Enquiries</h3>
			<p><a href="mailto:hello@veltaraworks.com" style="color: var(--sl-color-accent);">hello@veltaraworks.com</a></p>
		</div>

		<div class="feature-card" style="margin-bottom: 2rem;">
			<h3>Enterprise Sales</h3>
			<p><a href="mailto:sales@veltaraworks.com" style="color: var(--sl-color-accent);">sales@veltaraworks.com</a></p>
			<p>For multi-server deployments, SLA requirements, and custom integrations.</p>
		</div>

		<div class="feature-card" style="margin-bottom: 2rem;">
			<h3>Technical Support</h3>
			<p><a href="mailto:support@vectismail.com" style="color: var(--sl-color-accent);">support@vectismail.com</a></p>
			<p>Pro and Enterprise customers receive priority support. Community users can open issues on <a href="https://github.com/Veltara-Works/vectis/issues" style="color: var(--sl-color-accent);">GitHub</a>.</p>
		</div>

		<div class="feature-card">
			<h3>GitHub</h3>
			<p><a href="https://github.com/Veltara-Works/vectis" style="color: var(--sl-color-accent);">github.com/Veltara-Works/vectis</a></p>
			<p>Bug reports, feature requests, and contributions.</p>
		</div>
	</section>

	<footer class="footer">
		<span>&copy; 2026 Veltara Works. All rights reserved.</span>
		<div>
			<a href="/docs/getting-started">Docs</a> &nbsp;&middot;&nbsp;
			<a href="https://github.com/Veltara-Works/vectis">GitHub</a> &nbsp;&middot;&nbsp;
			<a href="/contact">Contact</a>
		</div>
	</footer>
</body>
</html>
